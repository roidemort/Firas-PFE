// public/certificate.pug - CORRECTED VERSION
doctype html
html
  head
    style.
      .certifcate {
        margin: auto;
        width: #{backgroundWidth};
        height: #{backgroundHeight};
        max-width: 100%;
        border: dotted #ccc 2px;
        position: relative;
        font-family: Arial, sans-serif;
      }
      .certificate-img {
        position: absolute;
        width: 100%;
        height: 100%;
        object-fit: cover;
      }
      .title {
        transform: translate3d(#{titleTranslateX}, #{titleTranslateY}, 0px);
        color: rgba(0, 0, 0, 0.87);
        display: inline-flex;
        justify-content: center;
        align-items: center;
        text-align: center;
        position: relative;
        z-index: 1;
        box-sizing: border-box;
        padding: 10px;
        font-size: 42px;
        font-weight: bold;
        text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
      }
      .subTitle {
        transform: translate3d(#{subTitleTranslateX}, #{subTitleTranslateY}, 0px);
        color: rgba(0, 0, 0, 0.87);
        display: inline-flex;
        justify-content: center;
        align-items: center;
        text-align: center;
        position: relative;
        z-index: 1;
        box-sizing: border-box;
        padding: 10px;
        font-size: 28px;
        font-weight: bold;
        text-shadow: 1px 1px 2px rgba(0,0,0,0.3);
      }
      .description {
        transform: translate3d(#{descriptionTranslateX}, #{descriptionTranslateY}, 0px);
        color: rgba(0, 0, 0, 0.87);
        display: inline-flex;
        justify-content: center;
        align-items: center;
        text-align: center;
        position: relative;
        z-index: 1;
        box-sizing: border-box;
        padding: 10px;
        font-size: 20px;
        max-width: 500px;
        text-shadow: 1px 1px 2px rgba(0,0,0,0.2);
      }
      .signature-img {
        transform: translate3d(#{signatureTranslateX}, #{signatureTranslateY}, 0px);
        height: 80px;
        width: 200px;
        color: rgba(0, 0, 0, 0.87);
        display: inline-flex;
        justify-content: center;
        align-items: center;
        text-align: center;
        position: relative;
        z-index: 1;
        box-sizing: border-box;
        padding: 10px;
        background-repeat: no-repeat;
        background-size: contain;
        background-position: center;
      }
  body
    .certifcate
      img.certificate-img(src=background)
      .title #{title}
      .subTitle #{subTitle}
      .description #{description}
      img.signature-img(src=signature)