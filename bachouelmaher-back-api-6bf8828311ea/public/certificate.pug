// public/certificate.pug - UPDATED VERSION
doctype html
html
  head
    meta(charset="UTF-8")
    style.
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      
      body {
        margin: 0;
        padding: 0;
        width: 100vw;
        height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        background: #f5f5f5;
      }
      
      .certificate-container {
        width: #{backgroundWidth};
        height: #{backgroundHeight};
        position: relative;
        overflow: hidden;
        margin: 0 auto;
        page-break-inside: avoid;
        page-break-after: avoid;
        page-break-before: avoid;
      }
      
      .certificate-img {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: contain;
        z-index: 0;
      }
      
      .title {
        position: absolute;
        transform: translate(#{titleTranslateX}, #{titleTranslateY});
        color: rgba(0, 0, 0, 0.87);
        text-align: center;
        z-index: 1;
        font-size: 42px;
        font-weight: bold;
        text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
        width: 80%;
        left: 10%;
      }
      
      .subTitle {
        position: absolute;
        transform: translate(#{subTitleTranslateX}, #{subTitleTranslateY});
        color: rgba(0, 0, 0, 0.87);
        text-align: center;
        z-index: 1;
        font-size: 28px;
        font-weight: bold;
        text-shadow: 1px 1px 2px rgba(0,0,0,0.3);
        width: 80%;
        left: 10%;
      }
      
      .description {
        position: absolute;
        transform: translate(#{descriptionTranslateX}, #{descriptionTranslateY});
        color: rgba(0, 0, 0, 0.87);
        text-align: center;
        z-index: 1;
        font-size: 20px;
        max-width: 500px;
        text-shadow: 1px 1px 2px rgba(0,0,0,0.2);
      }
      
      .signature-img {
        position: absolute;
        transform: translate(#{signatureTranslateX}, #{signatureTranslateY});
        height: 80px;
        width: 200px;
        object-fit: contain;
        z-index: 1;
      }
      
      /* Ensure single page */
      @page {
        size: landscape;
        margin: 0;
      }
      
      @media print {
        body {
          background: none;
        }
        .certificate-container {
          width: 100%;
          height: 100%;
        }
      }
  body
    .certificate-container
      img.certificate-img(src=background alt="Certificate Background")
      .title #{title}
      .subTitle #{subTitle}
      .description #{description}
      img.signature-img(src=signature alt="Signature")